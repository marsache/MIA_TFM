    <measure number="13">
      <print new-system="yes"/>
      <direction placement="below">
        <direction-type>
          <words>¡Ay, quién tuviera la pluma
</words>
          <words>que tuvo santa Teresa, 
</words>
          <words>para decirle a mi amante
</words>
          <words>lo que padezco en su ausencia!
</words>
          <words>Si tuviera pluma de oro
</words>
          <words>comprara papel de plata, 
</words>
          <words>pusiera cinco sentidos
</words>
          <words>para escribirte una carta.
</words>
          <words>Tres veces cogí la pluma, 
</words>
          <words>tres veces cogí el tintero, 
</words>
          <words>tres veces se me cayó
</words>
          <words>el corazón en el suelo.</words>
          </direction-type>
        </direction>
      <direction placement="below">
        <direction-type>
          <words>Tus ojos son dos tinteros, 
</words>
          <words>tu nariz, pluma delgada, 
</words>
          <words>tus dientes, letra menuda, 
</words>
          <words>tu boca, carta cerrada. 
</words>
          <words>Con el sol te escribo cartas, 
</words>
          <words>con la luna no me vale, 
</words>
          <words>con las estrellas te mando
</words>
          <words>recuerdos que te regalen.
</words>
          <words>Si se pudiera vivir
</words>
          <words>del cariño solamente, 
</words>
          <words>con el que yo te prometo
</words>
          <words>viviría eternamente.</words>
          </direction-type>
        </direction>
