          </direction-type>
        </direction>
      <direction placement="below">
        <direction-type>
          <words default-x="575" default-y="-202.49" valign="top">Me llamaste morenita:
</words>
          <words>la culpa tuvo la nieve
</words>
          <words>que no repartió conmigo
</words>
          <words>la hermosura que ella tiene.
</words>
          <words>
</words>
          <words>Morenas he visto yo,
</words>
          <words>pero como tú ninguna:
</words>
          <words>de tu cara sale el sol,
</words>
          <words>de tu garganta, la luna.</words>
          </direction-type>
        </direction>
      <direction placement="below">
        <direction-type>
          <words default-x="220" default-y="-200" valign="top">Me llamaste morenita
</words>
          <words>pensando que era bajeza:
</words>
          <words>me pusiste un ramillete
</words>
          <words>de los pies a la cabeza.
</words>
          <words>
</words>
          <words>De los pies a la cabeza
</words>
          <words>eres un ramo de flores;
</words>
          <words>bendita sea la madre
</words>
          <words>que por tí pasó dolores.</words>
          </direction-type>
        </direction>
