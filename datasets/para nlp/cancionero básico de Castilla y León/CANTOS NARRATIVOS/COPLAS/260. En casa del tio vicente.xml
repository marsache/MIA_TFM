    <measure number="11">
      <print new-system="yes"/>
      <direction placement="below">
        <direction-type>
          <words valign="top">Esta vieja copla, cantada en mucho lugares y con mucho textos diferentes, aparece por primera vez en 
</words>
          <words>la antología musical de Cantos Populares Españoles ( p. 160) , publicada en 1930 por Antonio Maryínez, 
</words>
          <words>con las siguiente letras,, con las que se ha difundido por refolklorizción, pasando como canción popular leonesa. </words>
          </direction-type>
        </direction>
      <direction placement="below">
        <direction-type>
          <words valign="top">En casa del tío Vicente, 
</words>
          <words>con tanta gente, 
</words>
          <words>¿qué habrá, que habrá?
</words>
          <words>Son los mocitos del pueblo, leré, 
</words>
          <words>que con las mozas, leré, 
</words>
          <words>quieren bailar. 
</words>
          <words>
</words>
          <words>El pobre del tío Vicente, 
</words>
          <words>con tanta gente, 
</words>
          <words>¿qué hará, qué hará?
</words>
          <words>Los hijos van por soldades, leré, 
</words>
          <words>y la Tomasa, leré
</words>
          <words>en su casa está. 
</words>
          <words>
</words>
          <words>La Lola tiene un chiquillo, 
</words>
          <words>ese chiquillo
</words>
          <words>¿de quien será?
</words>
          <words>No es de cuna ni es fraile,leré, 
</words>
          <words>que es del alcalde, leré, 
</words>
          <words>de la ciudad. 
</words>
          <words>
</words>
          <words>La Lola gasta pañales
</words>
