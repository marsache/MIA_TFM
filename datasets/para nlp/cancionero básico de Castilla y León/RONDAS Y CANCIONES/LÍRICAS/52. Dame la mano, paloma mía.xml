      <direction placement="below">
        <direction-type>
          <words valign="top">Porque te quiero, morena, 
</words>
          <words>me llevan a la prisión, 
</words>
          <words>me echan grillos y cadenas
</words>
          <words>como si fuera un ladrón. 
</words>
          <words>
</words>
          <words>Porque yo te quiero tanto
</words>
          <words>me llevan a otro lugar:
</words>
          <words>¡Cómo si la ausencia fuera
</words>
          <words>motivo para olvidar!
</words>
          <words>
</words>
          <words>Prisionero soy de amor
</words>
          <words>y lo seré mientras viva, 
</words>
          <words>que el prisionero de amor
</words>
          <words>primero muere que olvida. 
</words>
          <words>
</words>
          <words>Porque te quiero me dan
</words>
          <words>el hambre por alimento, 
</words>
          <words>y yo no puedo apartarme
</words>
          <words>de tu cariño un momento. 
</words>
          <words>
</words>
          <words>Dame la mano, 
</words>
          <words>paloma mía, 
</words>
          <words>que está cayendo, 
</words>
          <words>la nieve fría, 
</words>
          <words>Si está cayendo, que caiga, 
</words>
          <words>yo me arrimaré a una esquina, 
