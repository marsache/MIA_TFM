      <direction placement="below">
        <direction-type>
          <words valign="top">De tu puerta  al mía
</words>
          <words>va una cadena, 
</words>
          <words>por el suelo tendida, 
</words>
          <words>de amores llena, 
</words>
          <words>
</words>
