    <measure number="18">
      <print new-system="yes"/>
      <direction placement="below">
        <direction-type>
          <words valign="top">Calle de la barredera, 
</words>
          <words>de la barredera calle: 
</words>
          <words>quien te barre no te riega, 
</words>
          <words>quien te riega no te barre. 
</words>
          <words>
</words>
          <words>Tu nombre grabé en un árbol
</words>
          <words>y de la herida murió: 
</words>
          <words>murió de la misma suerte
</words>
          <words>que mi pobre corazón. 
</words>
          <words>
</words>
          <words>A tu puerta planté un pino, 
</words>
          <words>a tu ventana una parra, 
</words>
          <words>porque los rayos de sol
</words>
          <words>no te peguen en la cara. 
</words>
          <words>
</words>
          <words>La una cuendo va sola
</words>
          <words>no lleva tanto rigor
</words>
          <words>como lleva mi morena
</words>
          <words>cuando va a misa mayor. 
</words>
          <words>
</words>
          <words>El que me oyere cantar
</words>
          <words>dirá que no tengo juicio, 
</words>
          <words>ya puede considerar
</words>
          <words>que lo requiere el oficio. </words>
          </direction-type>
        </direction>
