          <words>soy militar, y te olvido por un real.</words>
          </direction-type>
        </direction>
      <direction placement="below">
        <direction-type>
          <words default-x="575" default-y="-174.69" valign="top">Has de saber que yo gasto
</words>
          <words>buen zapato y buena media,
</words>
          <words>has de saber que te olvido
</words>
          <words>por una perra pequeña.
</words>
          <words>
</words>
          <words>Allá va la despedida
</words>
          <words>metida en una cereza:
</words>
          <words>no canto ni bailo más,
</words>
          <words>que me duele la cabeza.</words>
          </direction-type>
        </direction>
      <direction placement="below">
        <direction-type>
          <words default-x="215" default-y="-173.02" valign="top">Yo soy el lindo Manuel
</words>
          <words>que trabaja en los alambres;
</words>
          <words>me gustan las buenas mozas, 
</words>
          <words>las pequeñas y las grandes.
</words>
          <words>
</words>
          <words>Quiéreme, que soy lañero,
</words>
          <words>tengo un oficio decente;
</words>
          <words>por las calles voy diciendo:
</words>
          <words>¡Barreños, platos y fuentes!</words>
          </direction-type>
        </direction>
