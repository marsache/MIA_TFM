    <measure number="14">
      <print new-system="yes"/>
      <direction placement="below">
        <direction-type>
          <words valign="top">Daime vino, daime vino, 
</words>
          <words>agua no he de beber, 
</words>
          <words>que anda una coca en el río, 
</words>
          <words>temo que me va a morder. 
</words>
          <words>
</words>
          <words>Arriba, galán, arriba, 
</words>
          <words>que más arriba estoy yo,
</words>
          <words>a beber agua de nieve, 
</words>
          <words>que también la bebo yo. 
</words>
          <words>
</words>
          <words>En el medio de la mar
</words>
          <words>hay una lechuga de oro;
</words>
          <words>tendrá pena de la vida
</words>
          <words>el que la corte el cogollo. 
</words>
          <words>
</words>
          <words>En Madrid, con ser Madrid, 
</words>
          <words>y con ser ciudad tan grande, 
</words>
          <words>sale el sol por la mañana
</words>
          <words>y se mete por la tarde.  </words>
          </direction-type>
        </direction>
      <note>
