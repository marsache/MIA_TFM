      <direction placement="below">
        <direction-type>
          <words default-x="576.11" default-y="-115.46" valign="top">Me dices que no me quieres
</words>
          <words>y me vienes a buscar
</words>
          <words>como la mar busca al río
</words>
          <words>y el río busca la mar.
</words>
          <words>
</words>
          <words>Agua arriba va la trucha,
</words>
          <words>agua arriba hasta la presa.
</words>
          <words>¡Cuántas cosas hace el hombre
</words>
          <words>que con el tiempo le pesan!
</words>
          <words>
</words>
          <words font-style="italic">Si pasas el río
</words>
          <words>no bebas el agua,
</words>
          <words>que la envenenaron 
</words>
          <words>los de la montaña.</words>
          </direction-type>
        </direction>
      <direction placement="below">
        <direction-type>
          <words default-x="190.52" default-y="-115.43" valign="top">Al pasar el río, madre,
</words>
          <words>yo me agarré a una mimbrera;
</words>
          <words>mejor me hubiera agarrado
</words>
          <words>a una mocita soltera.
</words>
          <words>
</words>
          <words>El el puente de Palencia
</words>
          <words>me puse a echar un cigarro;
</words>
          <words>me acordé de mi morena, 
</words>
          <words>se me cayó de la mano.
</words>
          <words>
</words>
          <words>Ay de mi, que me lo han roto,
</words>
          <words>el cantarito en la fuente;
</words>
          <words>no siento yo el cantarito,
</words>
          <words>sino qué dirá la gente.</words>
          </direction-type>
        </direction>
