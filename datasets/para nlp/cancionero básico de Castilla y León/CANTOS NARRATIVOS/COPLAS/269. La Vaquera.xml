    <measure number="14">
      <print new-system="yes"/>
      <direction placement="below">
        <direction-type>
          <words valign="top">Ya tenemos a la Juana
</words>
          <words>csada con un vaquero: 
</words>
          <words>teniendo tantos colchones
</words>
          <words>¡y está durmiendo en el suelo!
</words>
          <words>Los toreros dicen:
</words>
          <words>¡Vaya una vaquera!, 
</words>
          <words>con honda de plata, 
</words>
          <words>la tralla de seda.
</words>
          <words>
</words>
          <words>La vaquera escribe cartas
</words>
          <words>a su tío, que es alcalde:
</words>
          <words>Quea  alos pastores les diga
</words>
          <words>que no le saquen cantares, 
</words>
          <words>Los toreros dicen: 
</words>
          <words>
</words>
          <words>La Vaquera escribe cartas
</words>
          <words>al cura de Serranillos. 
</words>
          <words>Que pase por la caseta
</words>
          <words>a cristianas a un chiquillo. 
</words>
          <words>Y el cura responde:
</words>
          <words>Ni quiero, ni puedo, 
</words>
          <words>que de los novillos
</words>
          <words>me da mucho miedo.
</words>
          <words>
</words>
          <words>Por las calles de Madrid
</words>
          <words>se pasea una vaquera
</words>
          <words>con pañuelo de Manila: 
</words>
          <words>ya lo sabe España entera.
</words>
          <words>Los toreros dicen...</words>
          </direction-type>
        </direction>
