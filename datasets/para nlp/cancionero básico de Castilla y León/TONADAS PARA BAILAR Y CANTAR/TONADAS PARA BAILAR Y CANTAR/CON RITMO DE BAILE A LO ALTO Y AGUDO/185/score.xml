      <direction placement="below">
        <direction-type>
          <words default-x="7.73" default-y="-450.32" valign="top" font-style="italic">Arbolito florido,
</words>
          <words>dame tu sombra,
</words>
          <words>que me persigue el sueño
</words>
          <words>cuando estoy sola.</words>
          </direction-type>
        </direction>
      <direction placement="below">
        <direction-type>
          <words default-x="601.52" default-y="-162" valign="top">Me llamaste pobre y fea,
</words>
          <words>a un espeho me miré;
</words>
          <words>ojos de pícara tengo,
</words>
          <words>a algún tonto engañaré.
</words>
          <words>
</words>
          <words>La despedida les doy
</words>
          <words>metida en un coral fino:
</words>
          <words>con ésta no canto más, 
</words>
          <words>que le dejo </words>
          <words font-style="italic">pal </words>
          <words font-style="normal">domingo. </words>
          </direction-type>
        </direction>
      <direction placement="below">
        <direction-type>
          <words default-x="239.87" default-y="-161.87" valign="top">Aunque estoy aquí cantando, 
</words>
          <words>sabe Dios mi corazón:
</words>
          <words>lo tengo más amarillo
</words>
          <words>que la casca de un limón.
</words>
          <words>
</words>
          <words>Viva el sol, viva la luna, 
</words>
          <words>viva la flor del romero,
</words>
          <words>vivan las hijas de viuda,
</words>
          <words>que yo por una me muero.</words>
          </direction-type>
        </direction>
