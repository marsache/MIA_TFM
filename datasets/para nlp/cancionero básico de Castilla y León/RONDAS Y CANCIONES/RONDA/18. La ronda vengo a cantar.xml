      <direction placement="below">
        <direction-type>
          <words valign="top">La ronda vengo a cantar
</words>
          <words>con alegría y sin miedo; 
</words>
          <words>aq uien no tiene delito
</words>
          <words>no lo llevan prisionero. 
</words>
          <words>
</words>
          <words>Asómeta a la ventana, 
</words>
          <words>cara de luna brillante, 
</words>
          <words>que anque yo no te pretendo, 
</words>
          <words>conmigo viene tu amante. 
</words>
          <words>
</words>
          <words>Asómate a la ventana 
</words>
          <words>que te quiero preguntar 
</words>
          <words>dónde se esconde el amor, 
</words>
          <words>que yo lo quiero encontar. 
</words>
          <words>
</words>
          <words>Callecita, callecita, 
</words>
          <words>cuentas veces te he rondado, 
</words>
          <words>y las que te rondaré
</words>
          <words>si no me llevan soldado. 
</words>
          <words>
</words>
          <words>Despierta, niña, si duermes, 
</words>
          <words>que mañana dormirás, 
</words>
          <words>que no se pagan durmiendo
</words>
          <words>los ratos que a mí me das. 
</words>
          <words>
</words>
          <words>Allá va la despedida
</words>
          <words>con veinticinco claveles
</words>
          <words>y una ramita de olivo
</words>
          <words>para que de mí te acuerdes. </words>
          </direction-type>
