      <direction placement="below">
        <direction-type>
          <words valign="top">Ya está el pájaro verde
</words>
          <words>puesto en la esquina, 
</words>
          <words>del teberón, teberón
</words>
          <words>caracaracol, caracol, 
</words>
          <words>puesto en la esquina, 
</words>
          <words>puesto en la esquina, 
</words>
          <words>esperando a que llegue
</words>
          <words>la golondrina. (.)
</words>
          <words>
</words>
          <words>La golondrina suave
</words>
          <words>de pico leve, 
</words>
          <words>de pelo azabache, 
</words>
          <words>y ojitos verdes. 
</words>
          <words>
</words>
          <words>Si yo soy relamido
</words>
          <words>tú eres coquta, 
</words>
          <words>que cuando vas al baile
</words>
          <words>te pones hueca. 
</words>
          <words>
</words>
          <words>Si yo me pongo hueca
</words>
          <words>podré ponerme, 
</words>
          <words>que el majo que me ronda
</words>
          <words>pesetas tiene. 
</words>
          <words>
</words>
          <words>Pues si tiene pesetas
</words>
          <words>que la enseñe, 
</words>
          <words>te haremos un vestido
</words>
          <words>de seda verde. 
</words>
          <words>
</words>
          <words>Después de que vestida
</words>
          <words>le damos fuego
</words>
          <words>y verás cómo arde
</words>
          <words>el vestido nuevo. 
</words>
          <words>
</words>
          <words>*Se cantan las mismas repeticiones y se intercalan las muletillas. </words>
          </direction-type>
        </direction>
