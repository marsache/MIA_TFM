      <direction placement="below">
        <direction-type>
          <words default-y="-110" valign="top">A orillas de una fuente
</words>
          <words>una zagala ví, 
</words>
          <words>con el ruido del agua
</words>
          <words>yo me acerqué hasta allí
</words>
          <words>y oí una voz que decía:
</words>
          <words>¡Ay de mí, ay de mí, ay de mi!
</words>
          <words>
</words>
          <words>Como estaba solita
</words>
          <words>le declaré mi amor;
</words>
          <words>ellá quedó turbada
</words>
          <words>y nada me contestó; 
</words>
          <words>y dije para mí entonces:
</words>
          <words>Ya cayó, ya cayó, ya cayó. 
</words>
          <words>
</words>
          <words>Nos sentamos junto a un aárbol
</words>
          <words>varias hojas corté
</words>
          <words>se las metí en el pecho,
</words>
          <words>su cintura estreché, 
</words>
          <words>y entonces dijo la niña:
</words>
          <words>-Oh señor, qué atrevido es usted!
</words>
          <words>
</words>
          <words>La cogí de la mano, 
</words>
          <words>me la llevé al café, 
</words>
          <words>y en su precioso rostro
</words>
          <words>tres besos le estampé;
</words>
          <words> y entonces dijo la niña:
</words>
          <words>-Otros tres, otros tres, otros tres!
</words>
          <words>
</words>
          <words>Al despedirme de ella
</words>
          <words>mil abrazos de dio
</words>
          <words>y suspirando me dijo:
</words>
          <words>No me olvides, por Dios, 
</words>
          <words>bien sabes que el amor mío
</words>
          <words>sólo a tí, sólo a tí se rindió. </words>
          </direction-type>
        </direction>
