      <direction placement="below">
        <direction-type>
          <words default-y="-110" valign="top">De pequeñita fui lechera, 
</words>
          <words>muy feliz y muy dichosa, 
</words>
          <words>he necido en la montaña, 
</words>
          <words>muy cerquita de Reinosa. 
</words>
          <words>
</words>
          <words>Por hacer caso a un hombre, 
</words>
          <words>del pueblo fui murmurada
</words>
          <words>de los amores malditos
</words>
          <words>que me hicieron desgraciada.
</words>
          <words>
</words>
          <words>Sola me dejó en el mundo, 
</words>
          <words>dólo me dejó un recuerdo:
</words>
          <words>un niño de lindos ojos
</words>
          <words>que es un engelín del cielo. 
</words>
          <words>
</words>
          <words>Todas las noches del año
</words>
          <words>no duerme sin querer le cante
</words>
          <words>las canciones de aquel hombre
</words>
          <words>que anda por el mundo errante. 
</words>
          <words>
</words>
          <words>No quiero que por mi vuelva
</words>
          <words>ni cruce la carretera
</words>
          <words>ni quiero que nadie sepa
</words>
          <words>la vida de la lechera.</words>
          </direction-type>
        </direction>
