    <measure number="12">
      <print new-system="yes"/>
      <direction placement="below">
        <direction-type>
          <words valign="top">El palillo del tío Roque, (bis)
</words>
          <words>quieren que lo toque yo;
</words>
          <words>que lo toquen los mocitos, (bis)
</words>
          <words>que tienen la obligación. 
</words>
          <words>
</words>
          <words>La aceituna en el olivo
</words>
          <words>simepre se está meneando; 
</words>
          <words>igual te meneas tú, 
</words>
          <words>morena, si estás bailando. 
</words>
          <words>
</words>
          <words>La aceituna en el olivo, 
</words>
          <words>si no la cortan se pasa;
</words>
          <words>igual te pasará a ti, 
</words>
          <words>morena, si no te casas. 
</words>
          <words>
</words>
          <words>Mocitas, si quereis mozos, 
</words>
          <words>hacedlos de hierbabuena, 
</words>
          <words>que los mocitos de ahora
</words>
          <words>no salen de la taberna. 
</words>
          <words>
</words>
          <words>Este en el palillo, 
</words>
          <words>niá, del tío Roque; 
</words>
          <words>aquí te lo dejo
</words>
          <words>para que lo toques. </words>
          </direction-type>
        </direction>
