    <measure number="8">
      <print new-system="yes"/>
      <direction placement="below">
        <direction-type>
          <words valign="top">Si quieres oir, morena, 
</words>
          <words>los sacramentos cantar, 
</words>
          <words>escucha por un momento, 
</words>
          <words>que los voy a comenzar. 
</words>
          <words>
</words>
          <words>El primero es el Bautismo: 
</words>
          <words>ya sé que estás bautizada
</words>
          <words>en la pila de gracia
</words>
          <words>para ser mi enamorada. 
</words>
          <words>
</words>
          <words>Segundo es Confirmación; 
</words>
          <words>ya sé que estás confirmada, 
</words>
          <words>que te confirmó el obispo
</words>
          <words>para ser mi enamorada. 
</words>
          <words>
</words>
          <words>El tercero es Panitencia: 
</words>
          <words>penitencia ya me han dado 
</words>
          <words>con venirte a visitar
</words>
          <words>todos los días del año. 
</words>
          <words>
</words>
          <words>El cuarto es la Comunión, 
</words>
          <words>la que dan a los enfermos, 
</words>
          <words>bien pudieran drame a mí, 
</words>
          <words>que por tus amores muero. 
</words>
          <words>
</words>
          <words>El quinto de Estremaunción, 
</words>
          <words>con el extremo yo te requiero, 
</words>
          <words>ni de día, ni de noche 
</words>
          <words>de pensar en tí no duermo, 
</words>
          <words>
</words>
          <words>El sexto sacerdotal: 
</words>
          <words>yo cura no lo he de ser, 
</words>
          <words>que los libros del amor
</words>
          <words>toda la vida estudié. 
</words>
          <words>
</words>
          <words>Y el séptimo es Matrimonio; 
</words>
          <words>esto vengo a desear: 
</words>
          <words>si Dios de los cielos quiere, 
</words>
          <words>contigo me he de casar. 
</words>
          <words>
</words>
          <words></words>
          </direction-type>
        </direction>
