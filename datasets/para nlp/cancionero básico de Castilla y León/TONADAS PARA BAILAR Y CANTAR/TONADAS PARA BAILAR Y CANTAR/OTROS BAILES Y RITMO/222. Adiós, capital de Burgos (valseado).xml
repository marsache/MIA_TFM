      <direction placement="below">
        <direction-type>
          <words valign="top">Adiós, capital de Burgos, 
</words>
          <words>recuerdos tengo de ti, 
</words>
          <words>que quise a una burgalesa
</words>
          <words>y ella no me quiso a mí. 
</words>
          <words>
</words>
          <words>Y ella no me quiso a mí, 
</words>
          <words>y con otro se marchó, 
</words>
          <words>y ahora anda averiguando
</words>
          <words>las vidad que traigo yo. 
</words>
          <words>
</words>
          <words>Las vidas que traigo yo 
</words>
          <words>son fáciles de aprender:
</words>
          <words>ando robando y matando
</words>
          <words>por una ingrata mujer. 
</words>
          <words>
</words>
          <words>Por una ingrata mujer
</words>
          <words>me llevan a prisión
</words>
          <words>me echan cadenas y grillos, 
</words>
          <words>como si fuera un ladrón. 
</words>
          <words>
</words>
          <words>Me llevan a la prisión, 
</words>
          <words>me llevan al hospital, 
</words>
          <words>a curarame las heridad
</words>
          <words>que no se pueden curar. 
</words>
          <words>
</words>
          <words>Las heridad que yo tengo 
</words>
          <words>nadie me las curará, 
</words>
          <words>que quise a una burgalesa
</words>
          <words>y no la puedo olvidar. </words>
          </direction-type>
        </direction>
