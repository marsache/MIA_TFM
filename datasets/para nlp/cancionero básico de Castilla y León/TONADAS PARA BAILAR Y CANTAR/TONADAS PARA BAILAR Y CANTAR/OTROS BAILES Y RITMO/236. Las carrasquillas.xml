      <print new-system="yes"/>
      <direction placement="below">
        <direction-type>
          <words valign="top">Si quieres que yo te quiera, 
</words>
          <words>hemos de hacer un ajuste:
</words>
          <words>de que tú no hables con otra, 
</words>
          <words>y yo, con el que me guste. 
</words>
          <words>
</words>
          <words>¿Cómo quieres que te quiera, 
</words>
          <words>si te perdí la aficción?
</words>
          <words>La barrí con una escoba
</words>
          <words>dentro de mi corazón. 
</words>
          <words>
</words>
          <words>Este baile de la carrasquillas
</words>
          <words>es un baile muy disimiulado, 
</words>
          <words>que en echando la rodilla en tierra,
</words>
          <words>este baile se queda parado; 
</words>
          <words>media vuelta se dan en Madrid, 
</words>
          <words>en mi tierra no se baila, así, 
</words>
          <words>que se baila de espalda, de espalda, 
</words>
          <words>maquiquita, menea esa falda, 
</words>
          <words>mariquieta, que no digo eso, 
</words>
          <words>y a la vuelta me das un abrazo;
</words>
          <words>en mi tierra no se una eso, 
</words>
          <words>que se una un abrazo y un beso.  
</words>
          <words></words>
          </direction-type>
        </direction>
