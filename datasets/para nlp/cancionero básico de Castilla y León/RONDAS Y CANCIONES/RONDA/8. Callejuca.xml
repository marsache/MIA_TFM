      <direction placement="below">
        <direction-type>
          <words>Callejuca, callejuca, 
</words>
          <words>cuántes veces te he rondado, 
</words>
          <words>y las que te rondaré
</words>
          <words>si no me llevan soldado. 
</words>
          <words>Esta noche rondo yo, 
</words>
          <words>ponte niña, a la ventana; 
</words>
          <words>para la noche que viene, 
</words>
          <words>ronde quie le dé la gana.
</words>
          <words>Esta calle sí que es calle, 
</words>
          <words>éstas sí que son paredes, 
</words>
          <words>donde está el oro y la plata
</words>
          <words>y la sal de las mujeres. 
</words>
          <words>La ronda y la contrarronda
</words>
          <words>se encontraron en la calle; 
</words>
          <words>pudo más la contrarronda
</words>
          <words>que la ronda, con ser grande. 
</words>
          <words>- A la puerta llaman, sal a ver quién es. 
</words>
          <words>- Es un marinero, madre, que me viene a pretender. 
</words>
          <words>- Mándale que suba, que le quiero ver. </words>
