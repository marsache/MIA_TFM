</words>
          <words>eres del olor de la hierbabuena. 
</words>
          <words>
</words>
          <words>¿Cómo quieres que cante
</words>
          <words>con alegría, 
</words>
          <words>si en un valle de penas
</words>
          <words>estoy metida?
</words>
          <words>Ay, morena...
</words>
          <words>
</words>
          <words>A la luna de enero 
</words>
          <words>te he comparado 
</words>
          <words>que es la luna más clara
</words>
          <words>de todo el año.
</words>
          <words>Ay, morena...
</words>
          <words>
</words>
          <words>El alma ya me duele
</words>
          <words>de suplicarte
</words>
          <words>que me des un remedio
</words>
          <words>para olvidarte, 
</words>
          <words>
</words>
          <words>Ay morena...
</words>
          <words>Arroyito, arroyito, 
</words>
          <words>arroyo, arroyo, 
